# ─────────────────────────────────────────────────────────────────────────────
# DotSync Server — Environment Variables
# Copy this to .env and fill in your values before running.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# Frontend URL (for CORS — your Next.js URL)
FRONTEND_URL=http://localhost:3000

# Path to migrations folder (relative to binary or absolute)
MIGRATIONS_PATH=./migrations

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:      https://your-app.railway.app
# Callback URL:      https://your-app.railway.app/api/auth/github/callback
#                    (or http://localhost:8080/api/auth/github/callback for local dev)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — get from: https://dashboard.stripe.com/webhooks
# (after adding the webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
