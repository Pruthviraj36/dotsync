# ═══════════════════════════════════════════════════════════════════════════
#  DotSync Server — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#  Setup:
#    1. Copy this file:        cp .env.example .env
#    2. Fill in every value below (see the comment above each one for where
#       to get it).
#    3. Never commit .env — it's already in .gitignore.
#
#  ⚠️  This file (.env.example) must only ever contain PLACEHOLDER values.
#      If you paste a real secret here by mistake, treat it as compromised:
#      rotate it immediately, even if you remove it again right after.
# ═══════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────
#  SERVER
# ───────────────────────────────────────────────────────────────────────────

# Port the server listens on.
# Local dev: set this. On Render: leave unset — Render injects PORT itself.
PORT=8080

# Your frontend's URL, used for CORS. Update for production.
FRONTEND_URL=http://localhost:3000

# Path to the migrations folder (relative to the binary, or absolute).
MIGRATIONS_PATH=./migrations


# ───────────────────────────────────────────────────────────────────────────
#  DATABASE — Neon (https://neon.tech)
# ───────────────────────────────────────────────────────────────────────────
#  Create a project at neon.tech, then open Dashboard → Connection Details
#  to copy both connection strings below. Neon gives you two variants:
#
#    • Pooled (hostname contains "-pooler")  → use for DATABASE_URL
#    • Direct (no "-pooler" in hostname)      → use for DATABASE_URL_DIRECT
#
#  Migrations need the DIRECT connection — advisory locks used by
#  golang-migrate don't work reliably through PgBouncer's pooled connection.

DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require&channel_binding=require

DATABASE_URL_DIRECT=postgresql://<user>:<password>@<project>.<region>.aws.neon.tech/<database>?sslmode=require&channel_binding=require

# ── Local development without Neon ──
# Comment out the two lines above and uncomment these instead to use a
# local Postgres instance:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable
# DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable


# ───────────────────────────────────────────────────────────────────────────
#  AUTH — JWT
# ───────────────────────────────────────────────────────────────────────────
#  Generate a new secret locally — never reuse an example or a value you've
#  shared anywhere (chat, docs, screenshots):
#
#    openssl rand -hex 64
#
#  On Render: instead of pasting a value, set `generateValue: true` for this
#  key in render.yaml and let Render generate + store it for you.

JWT_SECRET=<run: openssl rand -hex 64>


# ───────────────────────────────────────────────────────────────────────────
#  GITHUB OAUTH
# ───────────────────────────────────────────────────────────────────────────
#  Create an OAuth App at:
#    https://github.com/settings/developers → OAuth Apps → New OAuth App
#
#  Homepage URL:   https://<your-app>.onrender.com
#  Callback URL:   https://<your-app>.onrender.com/api/auth/github/callback
#                  (use http://localhost:8080/api/auth/github/callback for local dev)

GITHUB_CLIENT_ID=<your_github_oauth_client_id>
GITHUB_CLIENT_SECRET=<your_github_oauth_client_secret>


# ───────────────────────────────────────────────────────────────────────────
#  STRIPE
# ───────────────────────────────────────────────────────────────────────────
#  Secret key:      https://dashboard.stripe.com/apikeys
#  Webhook secret:  https://dashboard.stripe.com/webhooks
#                   → add endpoint: https://<your-app>.onrender.com/api/stripe/webhook

STRIPE_SECRET_KEY=sk_test_<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=whsec_<your_stripe_webhook_secret>
