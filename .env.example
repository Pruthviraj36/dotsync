# ═══════════════════════════════════════════════════════════════════════════
#  DotSync Server — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#  1. cp .env.example .env
#  2. Fill in every value
#  3. Never commit .env
#
#  ⚠️  This file must only ever contain PLACEHOLDER values.
#      Real secrets here = compromised secrets. Run scripts/check-env-example.sh
#      before every commit.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
# On Render: omit PORT — Render injects it automatically as 10000
FRONTEND_URL=http://localhost:3000
MIGRATIONS_PATH=./migrations

# ── Database (Neon) ───────────────────────────────────────────────────────
# Neon dashboard → Connection Details → two variants:
#   Pooled (hostname has "-pooler"): use for DATABASE_URL  (app queries)
#   Direct (no "-pooler"):           use for DATABASE_URL_DIRECT  (migrations)
DATABASE_URL=postgresql://<user>:<password>@<ep>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL_DIRECT=postgresql://<user>:<password>@<ep>.<region>.aws.neon.tech/<db>?sslmode=require

# Local dev without Neon — uncomment and comment the two lines above:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable
# DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable

# ── Auth (JWT) ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
# On Render: use generateValue: true in render.yaml instead of pasting a value.
JWT_SECRET=<run: openssl rand -hex 64>

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# Create at: github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:  https://<your-app>.onrender.com
# Callback URL:  (not needed — login uses GitHub's Device Flow, no redirect)
# Advanced:      ✅ Enable Device Flow (required)
#
# Note: GITHUB_CLIENT_SECRET is intentionally NOT listed here. The Device
# Flow exchanges tokens directly between the CLI and GitHub — the server
# is never involved and never needs the secret.
GITHUB_CLIENT_ID=<your_github_oauth_client_id>

# ── Stripe ────────────────────────────────────────────────────────────────
# Secret key:     https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
#   Add endpoint: https://<your-app>.onrender.com/api/stripe/webhook
STRIPE_SECRET_KEY=sk_test_<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=whsec_<your_stripe_webhook_secret>
