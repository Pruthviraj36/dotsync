# ─────────────────────────────────────────────────────────────────────────────
# DotSync Server — Environment Variables
# Copy this to .env and fill in your values before running.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
# On Render, PORT is set automatically to 10000 — leave it unset there.

# Frontend URL (for CORS — your Next.js URL)
FRONTEND_URL=http://localhost:3000

# Path to migrations folder (relative to binary or absolute)
MIGRATIONS_PATH=./migrations

# ── Database (Neon) ──────────────────────────────────────────────────────────
# Create a project at https://neon.tech, then copy both connection strings
# from the Neon dashboard → Connection Details.

# Pooled connection (via PgBouncer) — used for normal app queries.
# Note the "-pooler" in the hostname.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dotsync?sslmode=require

# Direct (unpooled) connection — required for running migrations.
# Migrations use advisory locks which don't work reliably through PgBouncer.
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxx.region.aws.neon.tech/dotsync?sslmode=require

# For local dev without Neon, point both at a local Postgres instance instead:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable
# DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/dotsync?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 64
# On Render, set generateValue: true in render.yaml to auto-generate.
JWT_SECRET=c1fc7474e196ec51e604485e69edf26d503f66e06d0aea71ff56224ba838cd230f8526802ceef57484c2a494629913b657c7b331f7e152727c67b09f5c1cbe25d

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:      https://your-app.onrender.com
# Callback URL:      https://your-app.onrender.com/api/auth/github/callback
#                    (or http://localhost:8080/api/auth/github/callback for local dev)
GITHUB_CLIENT_ID=Ov23li9TRnKZVCb9pBbs
GITHUB_CLIENT_SECRET=8fc57b1918d458606a4c2c3de6903ee4baa2390e

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — get from: https://dashboard.stripe.com/webhooks
# Add endpoint: https://your-app.onrender.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
